              "repo": "https://github.com/curl/curl.git",
              "events": [
                {
                  "introduced": "e56ae1426cb7a0a4a427cf8d6099a821fdaae428"
                },
                {
                  "fixed": "f1a39f221d57354990e3eeeddc3404aede2aff70"
                }
              ]
            }
          ],
          "versions": 170,
          "database_specific": "<Any value>"
        }
      ],
      "schema_version": "1.7.5",
      "credits": [
        {
          "name": "Zhicheng Chen",
          "type": "FINDER"
